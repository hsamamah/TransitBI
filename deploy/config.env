# =============================================================
# Seattle Transit DW — Project Configuration
# =============================================================
# Sourced by all deploy scripts. No secrets here — credentials
# come from AWS CLI profile / IAM role at runtime.
#
# Usage in deploy scripts:
#   set -a; source "$(dirname "$0")/config.env"; set +a
# =============================================================

# ── AWS ───────────────────────────────────────────────────────
REGION="us-west-2"
ACCOUNT="805699509606"

# ── S3 ────────────────────────────────────────────────────────
S3_RAW="seattle-transit-raw"
S3_STAGING="seattle-transit-staging"
S3_PROCESSED="seattle-transit-processed"

# Script version prefix — bump to v3, v4 etc on breaking changes
SCRIPT_VERSION="v2"
SCRIPTS="s3://${S3_STAGING}/glue-scripts/${SCRIPT_VERSION}"

# ── IAM ───────────────────────────────────────────────────────
GLUE_ROLE="arn:aws:iam::${ACCOUNT}:role/TransitGlueRole"
REDSHIFT_COPY_ROLE="arn:aws:iam::${ACCOUNT}:role/RedshiftS3CopyRole"

# ── Glue ──────────────────────────────────────────────────────
GLUE_VERSION="4.0"
WORKER_TYPE="G.1X"

# ── Redshift ──────────────────────────────────────────────────
RS_WORKGROUP="team"
RS_NAMESPACE="transit"
RS_DATABASE="dev"
RS_ENDPOINT="team.${ACCOUNT}.${REGION}.redshift-serverless.amazonaws.com:5439/dev"

# ── DynamoDB ──────────────────────────────────────────────────
DYNAMODB_PIPELINE_TABLE="seattle-transit-pipeline"

# ── Workflows ─────────────────────────────────────────────────
WORKFLOW_STATIC="gtfs-static-pipeline"
WORKFLOW_RT="gtfs-rt-daily-pipeline"

# ── Schedules (cron in UTC) ───────────────────────────────────
# Static pipeline: 07:00 PST = 14:00 UTC
SCHEDULE_STATIC="cron(0 14 * * ? *)"
# RT pipeline:     08:00 PST = 15:00 UTC (after static completes)
SCHEDULE_RT="cron(0 15 * * ? *)"

# ── Resource Tags ─────────────────────────────────────────────
# Applied to every resource created by deploy scripts
TAGS="Project=seattle-transit-dw Environment=prod Team=DAMG7370 ManagedBy=deploy-script"

# ── Notifications ─────────────────────────────────────────────
FAILURE_SNS_TOPIC="transit-failure-alerts"
FAILURE_SNS_ARN="arn:aws:sns:${REGION}:${ACCOUNT}:transit-failure-alerts"
FAILURE_NOTIFIER_LAMBDA="transit-failure-notifier"

# ── QuickSight ────────────────────────────────────────────────
QS_ACCOUNT="${ACCOUNT}"
QS_VPC="vpc-0a11677a4786d95db"
QS_SECURITY_GROUP="sg-0f60cd6f1db33cff9"
